@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --op: #F47920;
  --op-dark: #C45E10;
}

* { box-sizing: border-box; }
html, body { padding: 0; margin: 0; }
body {
  background: #0A0A0A;
  color: #F5F5F5;
  font-family: 'Barlow', sans-serif;
  -webkit-font-smoothing: antialiased;
}

::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: #0A0A0A; }
::-webkit-scrollbar-thumb { background: var(--op); border-radius: 0; }

/* angular clip used across CTAs */
.clip-chevron {
  clip-path: polygon(10px 0%, 100% 0%, calc(100% - 10px) 100%, 0% 100%);
}
.clip-chevron-sm {
  clip-path: polygon(6px 0%, 100% 0%, calc(100% - 6px) 100%, 0% 100%);
}

/* racing dashed separator */
.race-line {
  height: 2px;
  background: repeating-linear-gradient(90deg, var(--op) 0, var(--op) 20px, transparent 20px, transparent 28px);
}

/* scanning line for analysis step */
.scan-line {
  position: absolute;
  left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, transparent, var(--op), transparent);
  box-shadow: 0 0 14px 2px rgba(244,121,32,0.7);
}

.grain::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.03) 1px, transparent 0);
  background-size: 4px 4px;
  pointer-events: none;
}

input[type="range"].op-range {
  -webkit-appearance: none;
  appearance: none;
  height: 3px;
  background: #333;
  outline: none;
}
input[type="range"].op-range::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 22px; height: 22px;
  background: var(--op);
  cursor: pointer;
  border: 3px solid #0A0A0A;
  box-shadow: 0 0 0 1px var(--op);
}
input[type="range"].op-range::-moz-range-thumb {
  width: 22px; height: 22px;
  background: var(--op);
  cursor: pointer;
  border: 3px solid #0A0A0A;
}
